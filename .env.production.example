# 本番（VPS公開）用の .env 雛形。これを .env にコピーして値を埋め、APP_KEY は VPS 上で生成すること。
#   cp .env.production.example .env
#   docker compose exec app php artisan key:generate   # 新規キーを必ず生成

APP_NAME="Recipe Bookmark"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP

# 登録を許可するレシピサイトのドメイン（カンマ区切り。サブドメインも自動許可）。
# 信頼できるドメインのみを列挙すること（取得はサーバ側で行うため）。
ALLOWED_RECIPE_DOMAINS=cookpad.com,kurashiru.com,delishkitchen.tv,recipe.rakuten.co.jp,kyounoryouri.jp,sirogohan.com

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=sqlite

# セッション（HTTPS前提）。SESSION_SECURE_COOKIE は必ず true。
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database

MAIL_MAILER=log
